{
    "manifest_version": 3,
    "name": "Pokemon Alolan Showdown",
    "description": "Changes the battle UI of Pokemon Showdown to one inspired by the Sun and Moon games.",
    "version": "1.0",
    "host_permissions": ["https://play.pokemonshowdown.com/*"],
    "content_scripts": [
        {
            "matches": [
                "https://play.pokemonshowdown.com/*"
            ],
            "js": [
                "app.js"
            ]
        }
    ],
    "icons": {
        "16": "images/icon-16.png",
        "32": "images/icon-32.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "permissions": [
        "storage", "tabs"
    ]
}